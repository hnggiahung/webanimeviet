<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <meta name="description" content="Ani VietSub VN - Xem phim hoạt hình anime online, chất lượng cao, cập nhật nhanh nhất" />
  <meta name="keywords" content="anime, phim anime, xem phim, streaming, hoạt hình, vietsub" />
  <meta name="theme-color" content="#0a0a0f" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
  <link rel="icon" type="image/x-icon" href="assets/favicon.ico" />
  <link rel="icon" type="image/png" href="assets/favicon.png" />
  <title>Ani VietSub VN - Xem Phim Anime Online</title>

  <!-- Web App Manifest -->
  <link rel="manifest" href="manifest.json" />

  <!-- I. RESOURCE PRELOADING: Preload banner images & logo -->
  <link rel="preload" as="image" href="logo.jpg.jpg" />
  <link rel="preload" as="image" href="https://img.ophim.live/uploads/movies/thumb_1.jpg" />
  
  <!-- I. CRITICAL CSS - Inline above-the-fold styles to avoid blocking -->
  <style>
    /* === CRITICAL: Above-the-fold styles === */
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
    html{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Inter,Roboto,Oxygen,Ubuntu,Cantarell,'Helvetica Neue',Arial,sans-serif;font-size:16px;line-height:1.5;-webkit-text-size-adjust:100%;scroll-behavior:smooth;touch-action:manipulation}
    body{font-family:inherit;background:#0a0a0f;color:#fff;overflow-x:hidden;min-height:100vh;min-height:100dvh;-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale}
    :root{--color-bg:#0a0a0f;--color-bg-secondary:#12121a;--color-surface:#1a1a24;--color-border:#222233;--color-text:#fff;--color-text-muted:#888899;--color-primary:#b8281e;--touch-target-min:44px}
    ::-webkit-scrollbar{width:6px;height:6px}::-webkit-scrollbar-track{background:var(--color-bg-secondary)}::-webkit-scrollbar-thumb{background:#333344;border-radius:3px}
    .movies-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:12px}
    @media(min-width:640px){.movies-grid{grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:16px}}
    @media(min-width:1024px){.movies-grid{grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:16px}}
    .movie-card{position:relative;border-radius:8px;overflow:hidden;background:var(--color-bg-secondary);border:1px solid var(--color-border);cursor:pointer;transition:border-color .15s ease,transform .15s ease;will-change:transform;min-height:var(--touch-target-min)}
    .movie-card-img{width:100%;aspect-ratio:2/3;object-fit:cover;display:block;background:#1e1e2a;transition:opacity .2s ease}
    .movie-card-img[loading="lazy"]{opacity:0}.movie-card-img.loaded,.movie-card-img[loading="eager"]{opacity:1}
    .movie-info{padding:10px 12px 12px}
    .movie-title{color:var(--color-text);font-weight:700;font-size:14px;line-height:1.3;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .movie-meta{display:flex;align-items:center;gap:6px;margin-top:4px;font-size:11px;color:var(--color-text-muted)}
    .episode-badge{position:absolute;top:8px;right:8px;z-index:5;padding:3px 8px;background:rgba(0,0,0,.7);color:#fff;font-size:11px;font-weight:700;border-radius:999px;line-height:1.2;backdrop-filter:blur(2px)}
    .glass-card{backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);background:rgba(255,255,255,.02)}
    .banner-swiper{width:100%;height:200px;border-radius:.75rem;overflow:hidden;position:relative!important}
    @media(min-width:640px){.banner-swiper{height:240px;border-radius:1rem}}
    @media(min-width:768px){.banner-swiper{height:360px}}
    .banner-swiper .swiper-slide{position:relative;overflow:hidden;height:100%}
    .banner-swiper .swiper-slide img{width:100%;height:100%;object-fit:cover;object-position:center}
    .banner-slide-overlay{position:absolute;inset:0;z-index:10;background:linear-gradient(to top,rgba(0,0,0,.85) 0%,rgba(0,0,0,.4) 50%,transparent 100%);pointer-events:none}
    .banner-slide-content{position:absolute;bottom:0;left:0;right:0;z-index:15;padding:24px 20px 48px;pointer-events:auto}
    .banner-slide-content .banner-title{font-size:1.25rem;font-weight:700;color:#fff;line-height:1.2;margin-bottom:4px;text-shadow:0 2px 4px rgba(0,0,0,.5);display:-webkit-box;-webkit-line-clamp:1;-webkit-box-orient:vertical;overflow:hidden}
    @media(min-width:768px){.banner-slide-content .banner-title{font-size:1.875rem}}
    .filter-btn{background:rgba(180,40,30,.15);border:1px solid rgba(180,40,30,.25);color:#d1d5db;padding:8px 14px;border-radius:999px;cursor:pointer;display:inline-flex;align-items:center;gap:6px;font-size:13px;font-family:inherit;user-select:none;transition:all .2s ease;min-height:var(--touch-target-min)}
    .filter-btn.active{background:var(--color-primary);border-color:var(--color-primary);color:#fff}
    header.sticky{position:sticky;top:0;z-index:50;background:rgba(10,10,15,.8);border-bottom:1px solid rgba(255,255,255,.05)}
    .skeleton-poster{width:100%;aspect-ratio:2/3;background:#1e1e2a;position:relative;overflow:hidden}
    .skeleton-poster::after{content:'';position:absolute;top:0;left:-100%;width:100%;height:100%;background:linear-gradient(90deg,transparent,#2a2a3a,transparent);animation:sk-shimmer 1.5s infinite}
    .skeleton-title{height:14px;background:#1e1e2a;border-radius:4px;margin-bottom:8px;position:relative;overflow:hidden}
    .skeleton-title::after{content:'';position:absolute;top:0;left:-100%;width:100%;height:100%;background:linear-gradient(90deg,transparent,#2a2a3a,transparent);animation:sk-shimmer 1.5s infinite}
    .skeleton-meta{height:10px;width:60%;background:#1e1e2a;border-radius:4px;position:relative;overflow:hidden}
    .skeleton-meta::after{content:'';position:absolute;top:0;left:-100%;width:100%;height:100%;background:linear-gradient(90deg,transparent,#2a2a3a,transparent);animation:sk-shimmer 1.5s infinite}
    @keyframes sk-shimmer{0%{left:-100%}100%{left:100%}}
    .search-suggestions{position:absolute;top:calc(100%+4px);left:0;right:0;background:var(--color-bg-secondary);border:1px solid var(--color-border);border-radius:8px;overflow:hidden;z-index:100;display:none;max-height:320px;overflow-y:auto}
    .search-suggestions.active{display:block}
    .banner-swiper .swiper-pagination{bottom:12px!important;z-index:20}
    .banner-swiper .swiper-pagination-bullet{width:8px;height:8px;background:rgba(255,255,255,.3);opacity:1;border-radius:999px;transition:all .3s}
    .banner-swiper .swiper-pagination-bullet-active{width:20px;background:#d1d5db}
    .mobile-overlay,.overlay-bg{display:none}
  </style>

  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>

  <!-- Swiper.js CSS -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

  <script>
    tailwind.config = {
      theme: { extend: { aspectRatio: { '3/4': '3 / 4' } } }
    }
  </script>

  <!-- Custom CSS -->
  <link rel="stylesheet" href="css/style.css" />
</head>
<body class="bg-[#0a0a0f] min-h-screen">
  <!-- HEADER -->
  <header class="sticky top-0 z-50 bg-[#0a0a0f]/80 border-b border-white/5">
    <div class="max-w-7xl mx-auto px-4 h-14 flex items-center justify-between">
      <!-- Logo with eager loading (above-fold priority) -->
      <a href="home.html" class="flex items-center shrink-0">
        <img src="logo.jpg.jpg" alt="AnimeStream Logo" class="w-10 h-10 rounded-full object-cover" loading="eager" width="40" height="40" />
      </a>

      <!-- Navigation + Search (Desktop) -->
      <nav class="hidden md:flex items-center gap-1">
        <a href="home.html" class="px-3 py-1.5 text-sm font-medium text-gray-300 hover:text-white touch-action-manipulation">Trang Chủ</a>
        <a href="#" class="px-3 py-1.5 text-sm font-medium text-gray-300 hover:text-white touch-action-manipulation">Dạng Anime</a>
        <a href="#" class="px-3 py-1.5 text-sm font-medium text-gray-300 hover:text-white touch-action-manipulation">Top Anime</a>
        <a href="#" class="px-3 py-1.5 text-sm font-medium text-gray-300 hover:text-white touch-action-manipulation">Thể Loại</a>
        <a href="#" class="px-3 py-1.5 text-sm font-medium text-gray-300 hover:text-white touch-action-manipulation">Season</a>
        <a href="#" class="px-3 py-1.5 text-sm font-medium text-gray-300 hover:text-white touch-action-manipulation">Thư Viện</a>
        <a href="#" class="px-3 py-1.5 text-sm font-medium text-gray-300 hover:text-white touch-action-manipulation">Lịch Chiếu</a>

        <!-- Divider -->
        <div class="w-px h-5 bg-white/10 mx-2"></div>

        <!-- Search -->
        <div class="relative search-bar w-[180px]">
          <div class="search-wrapper">
            <div class="flex items-center gap-2 bg-white/5 border border-white/10 rounded-full px-3 py-1.5 focus-within:border-gray-500">
              <svg class="text-gray-400 shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8"></circle>
                <path d="m21 21-4.35-4.35"></path>
              </svg>
              <input type="text" id="search-input" placeholder="Tìm kiếm..." class="w-full bg-transparent outline-none text-white placeholder-gray-500 text-sm" autocomplete="off" />
            </div>
            <!-- Search Suggestions Dropdown -->
            <div id="search-suggestions-desktop" class="search-suggestions">
              <ul id="suggestions-list-desktop"></ul>
            </div>
          </div>
        </div>

        <!-- Login Button -->
        <a href="#" 
           id="login-btn" 
           class="ml-2 px-3 py-1.5 bg-red-900/50 hover:bg-red-800/60 text-white text-sm font-medium rounded-full inline-flex items-center gap-1.5 touch-action-manipulation">
          Đăng nhập
        </a>
      </nav>

      <!-- Mobile: Search Icon + Hamburger -->
      <div class="md:hidden flex items-center gap-1">
        <button id="mobile-search-toggle" class="text-gray-400 hover:text-white p-2 rounded-full touch-action-manipulation" aria-label="Tìm kiếm">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.35-4.35"></path>
          </svg>
        </button>
        <button id="hamburger-btn" class="text-gray-300 hover:text-white p-2 rounded-full touch-action-manipulation" aria-label="Menu">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <line x1="3" y1="12" x2="21" y2="12"></line>
            <line x1="3" y1="18" x2="21" y2="18"></line>
          </svg>
        </button>
      </div>
      <!-- Mobile Search Bar -->
      <div id="mobile-search" class="hidden md:hidden w-full px-4 pb-3">
        <div class="search-wrapper">
          <div class="flex items-center gap-2 bg-white/5 border border-white/10 rounded-lg px-3 py-2 focus-within:border-gray-500">
            <svg class="text-gray-400 shrink-0" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8"></circle>
              <path d="m21 21-4.35-4.35"></path>
            </svg>
            <input type="text" id="search-input-mobile" placeholder="Tìm kiếm phim anime..." class="w-full bg-transparent outline-none text-white placeholder-gray-500 text-sm" autocomplete="off" />
          </div>
          <!-- Search Suggestions Dropdown Mobile -->
          <div id="search-suggestions-mobile" class="search-suggestions">
            <ul id="suggestions-list-mobile"></ul>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- Overlay background -->
  <div id="overlay-bg" class="overlay-bg"></div>

  <!-- ===== MOBILE OVERLAY MENU (Hamburger) ===== -->
  <div id="mobile-overlay" class="mobile-overlay">
    <div class="mobile-overlay-header">
      <span class="text-white font-bold text-base">Danh Mục</span>
      <button id="hamburger-close" class="text-gray-400 hover:text-white p-1 touch-action-manipulation" aria-label="Đóng menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
    <nav class="mobile-overlay-nav">
      <a href="home.html" class="mobile-overlay-link active">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path></svg>
        Trang Chủ
      </a>
      <a href="#" class="mobile-overlay-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polygon points="10 8 16 12 10 16" fill="currentColor"></polygon></svg>
        Dạng Anime
      </a>
      <a href="#" class="mobile-overlay-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
        Top Anime
      </a>
      <a href="#" class="mobile-overlay-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
        Thể Loại
      </a>
      <a href="#" class="mobile-overlay-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
        Season
      </a>
      <a href="#" class="mobile-overlay-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path></svg>
        Thư Viện
      </a>
      <a href="#" class="mobile-overlay-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line></svg>
        Lịch Chiếu
      </a>
    </nav>
    <div class="mobile-overlay-footer">
      <a href="#" id="login-btn-overlay" class="mobile-overlay-login">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"></path><polyline points="10 17 15 12 10 7"></polyline><line x1="15" y1="12" x2="3" y2="12"></line></svg>
        Đăng nhập
      </a>
    </div>
  </div>

  <!-- MAIN CONTENT: Grid Layout (2fr: Banner + Movies | 1fr: Sidebar) -->
  <section class="max-w-7xl mx-auto px-4 py-6">
    <div class="grid grid-cols-1 lg:grid-cols-[2fr,1fr] gap-6">
      <!-- LEFT COLUMN (2fr): Banner + Filter & Movies -->
      <div class="min-w-0 space-y-6">
        <!-- HERO BANNER - Swiper.js Slider -->
        <div id="hero-banner">
          <!-- Swiper container -->
          <div class="swiper banner-swiper" id="banner-swiper">
            <div class="swiper-wrapper" id="banner-swiper-wrapper">
              <!-- Các slide sẽ được JS inject động -->
              <div class="swiper-slide !flex items-center justify-center bg-gray-800">
                <div class="text-gray-400 text-sm">Đang tải banner...</div>
              </div>
            </div>
            <!-- Pagination dots -->
            <div class="swiper-pagination" id="banner-swiper-pagination"></div>
          </div>
        </div>

        <!-- Filter & Movies -->
        <div>
          <div class="flex flex-col md:flex-row items-center justify-between gap-4 mb-4">
            <h2 class="text-lg md:text-xl font-bold text-white">
              Danh Sách Phim Anime
            </h2>

            <!-- Category Filter -->
            <div class="flex flex-wrap gap-2 justify-center md:justify-end" id="filter-container">
              <button class="filter-btn active bg-red-800/60 border-red-700/50 rounded-full" data-category="all" data-slug="all">
                Tất Cả
              </button>
              <button class="filter-btn bg-red-900/40 border-red-800/30 rounded-full" data-category="hanh-dong" data-slug="hanh-dong">
                Hành Động
              </button>
              <button class="filter-btn bg-red-900/40 border-red-800/30 rounded-full" data-category="phieu-luu" data-slug="phieu-luu">
                Phiêu Lưu
              </button>
              <button class="filter-btn bg-red-900/40 border-red-800/30 rounded-full" data-category="chinh-kich" data-slug="chinh-kich">
                Chính Kịch
              </button>
              <button class="filter-btn bg-red-900/40 border-red-800/30 rounded-full" data-category="hoat-hinh" data-slug="hoat-hinh">
                🎬 Anime
              </button>
              <button class="filter-btn bg-red-900/40 border-red-800/30 rounded-full" data-category="sieu-nhan" data-slug="sieu-nhan">
                Siêu Nhân
              </button>
            </div>
          </div>

          <!-- III. SKELETON SCREEN: Grid skeleton hiển thị ngay lập tức -->
          <div class="movies-grid" id="movies-grid">
            <!-- Skeleton cards: 8 cards hiển thị ngay khi load -->
            <div class="skeleton-card"><div class="skeleton-poster"></div><div class="skeleton-info"><div class="skeleton-title"></div><div class="skeleton-meta"></div></div></div>
            <div class="skeleton-card"><div class="skeleton-poster"></div><div class="skeleton-info"><div class="skeleton-title"></div><div class="skeleton-meta"></div></div></div>
            <div class="skeleton-card"><div class="skeleton-poster"></div><div class="skeleton-info"><div class="skeleton-title"></div><div class="skeleton-meta"></div></div></div>
            <div class="skeleton-card"><div class="skeleton-poster"></div><div class="skeleton-info"><div class="skeleton-title"></div><div class="skeleton-meta"></div></div></div>
            <div class="skeleton-card"><div class="skeleton-poster"></div><div class="skeleton-info"><div class="skeleton-title"></div><div class="skeleton-meta"></div></div></div>
            <div class="skeleton-card"><div class="skeleton-poster"></div><div class="skeleton-info"><div class="skeleton-title"></div><div class="skeleton-meta"></div></div></div>
            <div class="skeleton-card"><div class="skeleton-poster"></div><div class="skeleton-info"><div class="skeleton-title"></div><div class="skeleton-meta"></div></div></div>
            <div class="skeleton-card"><div class="skeleton-poster"></div><div class="skeleton-info"><div class="skeleton-title"></div><div class="skeleton-meta"></div></div></div>
          </div>
        </div>

        <!-- MOBILE SIDEBAR -->
        <div class="lg:hidden space-y-5 mt-8" id="mobile-sidebar">
          <a href="#" id="random-anime-btn-mobile" class="block w-full px-4 py-3 bg-red-900/50 hover:bg-red-800/60 text-white text-sm font-bold rounded-full text-center touch-action-manipulation">
            🎲 Xem Anime Ngẫu Nhiên
          </a>

          <!-- Comments -->
          <div class="bg-[#1f1f1f] border border-white/5 rounded-2xl p-4">
            <h3 class="text-sm font-bold text-white mb-3 flex items-center gap-2 border-b border-white/5 pb-3">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-gray-400">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
              </svg>
              <span>Bình luận</span>
              <span class="text-gray-500 font-normal text-xs ml-auto bg-white/5 px-2 py-0.5 rounded-full">0</span>
            </h3>
            <div class="space-y-3 mb-4 max-h-[280px] overflow-y-auto scrollbar-thin">
              <div class="flex gap-2.5 p-2.5 bg-white/[0.03] rounded-xl hover:bg-white/[0.06]">
                <div class="w-8 h-8 rounded-full bg-gray-600 flex items-center justify-center text-white text-xs font-bold shrink-0 mt-0.5">H</div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-1.5 mb-0.5">
                    <span class="text-white text-xs font-semibold">Hoàng Gia Hưng</span>
                    <span class="px-1.5 py-0.5 text-[9px] font-bold bg-gray-600 text-gray-300 rounded">VIP</span>
                    <span class="text-gray-600 text-[10px] ml-auto">2 phút</span>
                  </div>
                  <p class="text-gray-400 text-xs leading-relaxed">Phim này hay quá ad Đang mong chờ tập tip</p>
                </div>
              </div>
              <div class="flex gap-2.5 p-2.5 bg-white/[0.03] rounded-xl hover:bg-white/[0.06]">
                <div class="w-8 h-8 rounded-full bg-gray-600 flex items-center justify-center text-white text-xs font-bold shrink-0 mt-0.5">M</div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-1.5 mb-0.5">
                    <span class="text-white text-xs font-semibold">Minh Anh</span>
                    <span class="text-gray-600 text-[10px] ml-auto">15 phút</span>
                  </div>
                  <p class="text-gray-400 text-xs leading-relaxed">Có ai biết khi nào ra tập mới không ạ</p>
                </div>
              </div>
