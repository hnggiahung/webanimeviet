  <!-- III. EVENT DELEGATION & Instant Search: Inline optimized script -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // ========== MOBILE SEARCH ==========
      const toggleBtn = document.getElementById('mobile-search-toggle');
      const mobileSearch = document.getElementById('mobile-search');
      if (toggleBtn && mobileSearch) {
        toggleBtn.addEventListener('click', () => {
          mobileSearch.classList.toggle('hidden');
          const input = document.getElementById('search-input-mobile');
          if (!mobileSearch.classList.contains('hidden')) {
            setTimeout(() => input.focus(), 100);
          }
        });
      }

      // Sync both search inputs
      const searchInput = document.getElementById('search-input');
      const searchInputMobile = document.getElementById('search-input-mobile');
      if (searchInput && searchInputMobile) {
        searchInput.addEventListener('input', (e) => {
          const val = e.target.value;
          searchInputMobile.value = val;
          if (typeof window.searchMovies === 'function') window.searchMovies(val);
          if (typeof window.showSuggestions === 'function') window.showSuggestions(val);
        });
        searchInputMobile.addEventListener('input', (e) => {
          const val = e.target.value;
          searchInput.value = val;
          if (typeof window.searchMovies === 'function') window.searchMovies(val);
          if (typeof window.showSuggestions === 'function') window.showSuggestions(val);
        });
        
        searchInput.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' && typeof window.searchMovies === 'function') {
            window.searchMovies(e.target.value);
            if (typeof window.hideAllSuggestions === 'function') window.hideAllSuggestions();
          }
        });
        searchInputMobile.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' && typeof window.searchMovies === 'function') {
            window.searchMovies(e.target.value);
            if (typeof window.hideAllSuggestions === 'function') window.hideAllSuggestions();
          }
        });

        searchInput.addEventListener('focus', (e) => {
          if (e.target.value.trim() && typeof window.showSuggestions === 'function') {
            window.showSuggestions(e.target.value);
          }
        });
        searchInputMobile.addEventListener('focus', (e) => {
          if (e.target.value.trim() && typeof window.showSuggestions === 'function') {
            window.showSuggestions(e.target.value);
          }
        });

        searchInput.addEventListener('blur', () => {
          setTimeout(() => { if (typeof window.hideAllSuggestions === 'function') window.hideAllSuggestions(); }, 200);
        });
        searchInputMobile.addEventListener('blur', () => {
          setTimeout(() => { if (typeof window.hideAllSuggestions === 'function') window.hideAllSuggestions(); }, 200);
        });
      }

      // Click outside to hide suggestions
      document.addEventListener('click', (e) => {
        const desktopDropdown = document.getElementById('search-suggestions-desktop');
        const mobileDropdown = document.getElementById('search-suggestions-mobile');
        const desktopWrapper = document.querySelector('.search-bar .search-wrapper');
        const mobileWrapper = document.querySelector('#mobile-search .search-wrapper');
        if (desktopDropdown && desktopWrapper && !desktopWrapper.contains(e.target) && !desktopDropdown.contains(e.target)) {
          desktopDropdown.classList.remove('active');
        }
        if (mobileDropdown && mobileWrapper && !mobileWrapper.contains(e.target) && !mobileDropdown.contains(e.target)) {
          mobileDropdown.classList.remove('active');
        }
      });

      // ========== MOBILE SIDEBAR: Random Anime Button (Mobile) ==========
      const randomBtnMobile = document.getElementById('random-anime-btn-mobile');
      if (randomBtnMobile) {
        randomBtnMobile.addEventListener('click', (e) => {
          e.preventDefault();
          if (typeof window.handleRandomAnime === 'function') {
            window.handleRandomAnime();
          }
        });
      }

      // ========== HAMBURGER MENU TOGGLE ==========
      const hamburgerBtn = document.getElementById('hamburger-btn');
      const hamburgerClose = document.getElementById('hamburger-close');
      const mobileOverlay = document.getElementById('mobile-overlay');
      const overlayBg = document.getElementById('overlay-bg');

      function openMenu() {
        if (mobileOverlay) mobileOverlay.classList.add('open');
        if (overlayBg) overlayBg.classList.add('open');
        document.body.style.overflow = 'hidden';
      }

      function closeMenu() {
        if (mobileOverlay) mobileOverlay.classList.remove('open');
        if (overlayBg) overlayBg.classList.remove('open');
        document.body.style.overflow = '';
      }

      if (hamburgerBtn) hamburgerBtn.addEventListener('click', openMenu);
      if (hamburgerClose) hamburgerClose.addEventListener('click', closeMenu);
      if (overlayBg) overlayBg.addEventListener('click', closeMenu);

      // Close menu on Escape key
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeMenu();
      });
    });
  </script>

  <!-- III. EVENT DELEGATION for filter buttons (single listener) -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // III. Event Delegation: 1 listener xử lý tất cả filter buttons
      const filterContainer = document.getElementById('filter-container');
      if (filterContainer) {
        filterContainer.addEventListener('click', function(e) {
          const btn = e.target.closest('.filter-btn');
          if (!btn) return;
          const category = btn.dataset.category;
          if (typeof window.filterByCategory === 'function') {
            window.filterByCategory(category);
          }
        });
      }
    });
  </script>

  <script src="js/main.js"></script>
</body>
